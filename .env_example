# Google Gemini (for both planning and chat agents)
# CrewAI expects GEMINI_API_KEY (not GOOGLE_API_KEY)
GEMINI_API_KEY=your_google_api_key

# OpenAI (Planning Agents: GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key

# OpenRouter
OPENROUTER_API_KEY=
OPENAI_API_BASE=https://openrouter.ai/api/v1
CHAT_MAX_TOKENS_DEFAULT=16000
CHAT_RETRY_TOKEN_BUFFER=256
PLANNING_MAX_TOKENS_DEFAULT=8192
PLANNING_RETRY_TOKEN_BUFFER=256
PLANNING_RETRY_MAX_TOKENS_ON_TRUNCATION=6144

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=everything_money
